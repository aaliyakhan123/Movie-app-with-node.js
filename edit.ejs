<%- include("header") %>

<main class="page-shell form-shell">
  <form class="movie-form" action="/update/<%= movie._id %>" method="POST" enctype="multipart/form-data">
    <div class="form-head">
      <h1>Edit Movie</h1>
      <a class="btn btn-secondary" href="/view-all">Back</a>
    </div>

    <div class="edit-preview">
      <% if (movie.poster) { %>
        <img src="/assets/uploads/<%= movie.poster %>" alt="<%= movie.title %> poster">
      <% } else { %>
        <div class="poster-placeholder"><%= movie.title.charAt(0).toUpperCase() %></div>
      <% } %>
      <div>
        <h2><%= movie.title %></h2>
        <p><%= movie.genre || "Movie" %><% if (movie.releaseYear) { %> &bull; <%= movie.releaseYear %><% } %></p>
      </div>
    </div>

    <div class="form-grid">
      <label>
        <span>Movie Title *</span>
        <input name="title" value="<%= movie.title %>" required>
      </label>

      <label>
        <span>Genre</span>
        <input name="genre" value="<%= movie.genre || '' %>">
      </label>

      <label>
        <span>Release Year</span>
        <input name="releaseYear" type="number" min="1900" max="2099" value="<%= movie.releaseYear || '' %>">
      </label>

      <label>
        <span>Duration</span>
        <input name="duration" value="<%= movie.duration || '' %>">
      </label>

      <label>
        <span>Rating</span>
        <input name="rating" type="number" min="0" max="10" step="0.1" value="<%= movie.rating || '' %>">
      </label>

      <label>
        <span>Language</span>
        <input name="language" value="<%= movie.language || '' %>">
      </label>

      <label>
        <span>Director</span>
        <input name="director" value="<%= movie.director || '' %>">
      </label>

      <label>
        <span>Cast</span>
        <input name="cast" value="<%= movie.cast || '' %>">
      </label>

      <label>
        <span>New Poster Image</span>
        <input name="poster" type="file" accept="image/*">
      </label>

      <label>
        <span>New Banner Image</span>
        <input name="banner" type="file" accept="image/*">
      </label>
    </div>

    <label class="wide-field">
      <span>Description</span>
      <textarea name="description"><%= movie.description || '' %></textarea>
    </label>

    <label class="check-field">
      <input name="isTrending" type="checkbox" <%= movie.isTrending ? "checked" : "" %>>
      <span>Trending Now</span>
    </label>

    <div class="form-actions">
      <a class="btn btn-secondary" href="/view-all">Cancel</a>
      <button class="btn btn-primary" type="submit">Update Movie</button>
    </div>
  </form>
</main>

<%- include("footer") %>
