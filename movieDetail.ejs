<%- include("header") %>

<main>
  <section class="detail-hero" style="background-image: url('<%= movie.banner ? `/assets/uploads/${movie.banner}` : '/assets/images/banner.png' %>')">
    <div class="detail-overlay"></div>
    <div class="detail-content">
      <div class="detail-poster">
        <% if (movie.poster) { %>
          <img src="/assets/uploads/<%= movie.poster %>" alt="<%= movie.title %> poster">
        <% } else { %>
          <div class="poster-placeholder"><%= movie.title.charAt(0).toUpperCase() %></div>
        <% } %>
      </div>
      <div class="detail-info">
        <h1><%= movie.title %></h1>
        <div class="meta-line">
          <% if (movie.releaseYear) { %><span><%= movie.releaseYear %></span><% } %>
          <% if (movie.genre) { %><span><%= movie.genre %></span><% } %>
          <% if (movie.duration) { %><span><%= movie.duration %></span><% } %>
          <% if (movie.rating) { %><span><%= movie.rating %>/10</span><% } %>
        </div>
        <% if (movie.description) { %>
          <p class="detail-desc"><%= movie.description %></p>
        <% } %>
        <div class="detail-extra">
          <% if (movie.language) { %><p><strong>Language:</strong> <%= movie.language %></p><% } %>
          <% if (movie.director) { %><p><strong>Director:</strong> <%= movie.director %></p><% } %>
          <% if (movie.cast) { %><p><strong>Cast:</strong> <%= movie.cast %></p><% } %>
        </div>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/edit/<%= movie._id %>">Edit</a>
          <a class="btn btn-secondary" href="/view-all">Back</a>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("footer") %>
